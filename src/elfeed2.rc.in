// Disable wxWidgets' default manifest — we provide our own with DPI
// awareness (it also covers themed common controls).
#define wxUSE_NO_MANIFEST 1
#include "wx/msw/wx.rc"

// Embed elfeed2.manifest as the standard application manifest
// (resource ID 1, RT_MANIFEST = 24). Without DPI awareness here,
// Windows bitmap-scales the window on high-DPI displays and text
// renders blurry.
1 24 "elfeed2.manifest"

// Application icon. Windows uses the lowest-numbered ICON resource
// as the .exe file icon; the same resource is loaded in code via
// wxICON("elfeed2") to set the title-bar / taskbar icon.
elfeed2 ICON "elfeed2.ico"

// VERSIONINFO populates the file properties Explorer shows in the
// Details tab and that Windows reports via GetFileVersionInfo.
// Substituted at configure time from CMake's PROJECT_VERSION_*.
#define VER_FILEVERSION       @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
#define VER_PRODUCTVERSION    @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
#define VER_FILEVERSION_STR    "@PROJECT_VERSION@\0"
#define VER_PRODUCTVERSION_STR "@PROJECT_VERSION@\0"

1 VERSIONINFO
FILEVERSION    VER_FILEVERSION
PRODUCTVERSION VER_PRODUCTVERSION
FILEFLAGSMASK  0x3FL
FILEFLAGS      0x0L
FILEOS         0x40004L  /* VOS_NT_WINDOWS32 */
FILETYPE       0x1L      /* VFT_APP */
FILESUBTYPE    0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        /* 040904B0 = English (US) + Unicode (1200). Matches the
           Translation entry in VarFileInfo below. */
        BLOCK "040904B0"
        BEGIN
            VALUE "CompanyName",      "skeeto\0"
            /* FileDescription / ProductName are display strings —
               capitalize. InternalName / OriginalFilename are
               technical identifiers tied to the lowercase binary
               name, so keep them as-is. */
            VALUE "FileDescription",  "Elfeed2 - feed reader\0"
            VALUE "FileVersion",      VER_FILEVERSION_STR
            VALUE "InternalName",     "elfeed2\0"
            VALUE "LegalCopyright",   "Public Domain (Unlicense)\0"
            VALUE "OriginalFilename", "elfeed2.exe\0"
            VALUE "ProductName",      "Elfeed2\0"
            VALUE "ProductVersion",   VER_PRODUCTVERSION_STR
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END
